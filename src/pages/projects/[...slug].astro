---
// D · /projects/[slug] template
import DLayout from '../../layouts/DLayout.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const projects = await getCollection('projects');
  return projects.map((p) => ({ params: { slug: p.id }, props: { p } }));
}

const { p } = Astro.props;
const { Content } = await render(p);

const STATUS_LABEL: Record<string, string> = {
  active: 'Active',
  shipped: 'Shipped',
  archived: 'Archived',
  validation: 'In validation',
};
---

<DLayout title={p.data.title} active="projects">
  <div style="font-family: var(--d-mono); font-size: 12px; color: var(--d-text3); margin-bottom: 36px;">
    <a href="/projects/" style="color: var(--d-accent);">/projects</a>
    <span style="margin: 0 6px;">/</span>{p.id}
  </div>

  <div style="display: flex; gap: 14px; font-family: var(--d-mono); font-size: 12px; color: var(--d-text3); margin-bottom: 22px; flex-wrap: wrap;">
    <span>{p.data.date.getFullYear()}</span>
    <span>·</span>
    <span style="color: var(--d-accent);">{STATUS_LABEL[p.data.status] ?? p.data.status}</span>
    {p.data.stack.length > 0 && <>
      <span>·</span>
      <span>{p.data.stack.join(' · ')}</span>
    </>}
  </div>

  <h1 style="font-family: var(--d-serif); font-weight: 400; font-size: 48px; line-height: 1.08; letter-spacing: -0.025em; margin: 0 0 18px;" class="d-h1">
    {p.data.title}
  </h1>
  {p.data.link && (
    <p style="font-family: var(--d-mono); font-size: 13px; margin: 0 0 36px;">
      <a href={p.data.link} target="_blank" rel="noopener" style="color: var(--d-accent);">{p.data.link.replace(/^https?:\/\//, '').replace(/\/$/, '')} ↗</a>
    </p>
  )}

  <div class="d-prose">
    <Content />
  </div>

  <div style="margin-top: 56px; padding: 20px 24px; background: var(--d-code); border-radius: 6px; font-family: var(--d-mono); font-size: 12.5px; color: var(--d-text2); line-height: 1.7;" class="d-end">
    <span style="color: var(--d-accent);">$</span> back <a href="/projects/" style="color: var(--d-accent);">./projects →</a>
  </div>
</DLayout>

<style is:global>
  /* reuses .d-prose styles defined in /posts/[...slug].astro */
</style>

<style>
  @media (max-width: 767px) {
    h1.d-h1 { font-size: 32px !important; line-height: 1.1 !important; }
  }
</style>
