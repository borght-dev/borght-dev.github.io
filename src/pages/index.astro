---
import Base from '../layouts/Base.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('posts', ({ data }) => !data.draft))
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime())
  .slice(0, 4);

const series = (await getCollection('series'))
  .sort((a, b) => a.data.title.localeCompare(b.data.title));

const fmt = (d: Date) => d.toISOString().slice(0, 10);

function readingTime(text: string): string {
  const words = text.trim().split(/\s+/).length;
  return `${Math.max(1, Math.ceil(words / 200))} min read`;
}
---

<Base title="Koen van der Borght" terminalPath="~/home">
  <section class="section">
    <h2 class="section-title">recent_posts</h2>
    <div class="posts-grid">
      { posts.length === 0 && (
        <p class="post-excerpt">No posts published yet — first drafts are queued in the content folder.</p>
      ) }
      { posts.map(post => (
        <a href={`/blog/${post.id}/`} class="post-card">
          <div class="post-meta">
            <span>{fmt(post.data.date)}</span>
            <span>•</span>
            <span>{readingTime(post.body ?? '')}</span>
          </div>
          <h3 class="post-title-card">{post.data.title}</h3>
          { post.data.subtitle && <p class="post-excerpt"><em>{post.data.subtitle}</em></p> }
          { post.data.description && <p class="post-excerpt">{post.data.description}</p> }
        </a>
      )) }
    </div>
  </section>

  <section class="section">
    <h2 class="section-title">active_series</h2>
    <div class="posts-grid">
      { series.map(s => (
        <a href={`/series/${s.data.seriesId}/`} class="post-card series-card">
          <span class="series-badge">{s.data.status}</span>
          <h3 class="post-title-card">{s.data.title}</h3>
          <p class="post-excerpt">{s.data.tagline}</p>
          { s.data.cadence && <p class="series-meta">cadence: {s.data.cadence}</p> }
        </a>
      )) }
    </div>
  </section>

  <section class="section">
    <h2 class="section-title">system_status</h2>
    <div class="status-grid">
      <div class="status-item">
        <div class="status-icon"></div>
        <div class="status-text">Currently: Coding</div>
      </div>
      <div class="status-item">
        <div class="status-icon"></div>
        <div class="status-text">Coffee level: ███████░░░ 75%</div>
      </div>
      <div class="status-item">
        <div class="status-icon"></div>
        <div class="status-text">Available for: Projects</div>
      </div>
      <div class="status-item">
        <div class="status-icon"></div>
        <div class="status-text">Location: /dev/home</div>
      </div>
    </div>
  </section>
</Base>
