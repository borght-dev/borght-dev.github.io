---
import Base from '../../layouts/Base.astro';
import { getCollection } from 'astro:content';

const series = (await getCollection('series'))
  .sort((a, b) => a.data.title.localeCompare(b.data.title));

const allEpisodes = await getCollection('episodes');
const epsFor = (id: string) => allEpisodes.filter(e => e.data.seriesId === id);
---

<Base title="Series" description="Multi-part deep-dives.">
  <section class="block">
    <div class="section-head">
      <span class="section-prompt">&gt;</span>
      <h2 class="section-title">all_series</h2>
      <span class="section-meta">{series.length} active</span>
    </div>
    <div class="series-grid">
      { series.map(s => {
        const eps = epsFor(s.data.seriesId);
        const pub = eps.filter(e => !e.data.draft).length;
        return (
          <a href={`/series/${s.data.seriesId}/`} class="series-card">
            <div class="series-status"><span class="pulse-dot"></span> {s.data.status}</div>
            <h3>{s.data.title}</h3>
            <p>{s.data.tagline}</p>
            <div class="meta">
              <span>{pub} / {eps.length} episodes</span>
              { s.data.cadence && <span>· {s.data.cadence}</span> }
            </div>
          </a>
        );
      }) }
    </div>
  </section>
</Base>
