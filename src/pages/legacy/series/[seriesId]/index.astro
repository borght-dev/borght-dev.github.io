---
import Base from '../../../../layouts/Base.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const series = await getCollection('series');
  return series.map(s => ({ params: { seriesId: s.data.seriesId }, props: { s } }));
}

const { s } = Astro.props;
const { Content } = await render(s);

const episodes = (await getCollection('episodes', e => e.data.seriesId === s.data.seriesId))
  .sort((a, b) => a.data.episode - b.data.episode);

const fmt = (d?: Date) => d ? d.toISOString().slice(0, 10) : '—';
const slugOf = (id: string) => id.split('/').pop();
---

<Base title={s.data.title} description={s.data.tagline}>
  <article class="article-shell">
    <nav class="breadcrumbs">
      <a href="/legacy/">~</a><span class="sep">/</span>
      <a href="/legacy/series/">series</a><span class="sep">/</span>
      <span>{s.data.seriesId}</span>
    </nav>

    <header class="article-header">
      <div class="series-status" style="margin-bottom:1rem;">
        <span class="pulse-dot"></span> {s.data.status}
        { s.data.cadence && <> · {s.data.cadence}</> }
      </div>
      <h1 class="article-title">{s.data.title}</h1>
      <p class="article-subtitle">{s.data.tagline}</p>
    </header>

    <div class="article-content">
      <Content />

      <h2>episodes</h2>
      <ul class="episode-list">
        { episodes.map(ep => {
          const slug = slugOf(ep.id);
          const href = ep.data.draft ? null : `/series/${s.data.seriesId}/${slug}/`;
          return (
            <li>
              { href ? (
                <a href={href}>
                  <span class="episode-num">ep{String(ep.data.episode).padStart(2, '0')}</span>
                  <span class="episode-title">{ep.data.title}</span>
                  <span class="episode-status published">{fmt(ep.data.date)}</span>
                </a>
              ) : (
                <a href="#" style="cursor:not-allowed;opacity:0.6;" aria-disabled="true">
                  <span class="episode-num">ep{String(ep.data.episode).padStart(2, '0')}</span>
                  <span class="episode-title">{ep.data.title}</span>
                  <span class="episode-status draft">draft</span>
                </a>
              ) }
            </li>
          );
        }) }
      </ul>
    </div>
  </article>
</Base>
