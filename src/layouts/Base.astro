---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

interface Props {
  title: string;
  description?: string;
  terminalPath?: string;
  tagline?: string;
  showHero?: boolean;
}

const {
  title,
  description = 'Senior developer, technical lead, and lifelong learner.',
  terminalPath = '~/home',
  tagline,
  showHero = true,
} = Astro.props;

const fullTitle = title === 'Koen van der Borght' ? title : `${title} | Koen van der Borght`;
const canonical = new URL(Astro.url.pathname, Astro.site).toString();
---

<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <meta name="description" content={description} />
  <meta name="generator" content={Astro.generator} />

  <link rel="icon" type="image/x-icon" href="/favicon.ico" />
  <link rel="canonical" href={canonical} />
  <link rel="alternate" type="application/rss+xml" href="/rss.xml" title="Koen van der Borght" />

  <meta property="og:type" content="website" />
  <meta property="og:url" content={canonical} />
  <meta property="og:title" content={fullTitle} />
  <meta property="og:description" content={description} />
  <meta property="twitter:card" content="summary_large_image" />
  <meta property="twitter:title" content={fullTitle} />
  <meta property="twitter:description" content={description} />

  <title>{fullTitle}</title>

  <script is:inline>
    const saved = localStorage.getItem('theme');
    if (saved === 'light') document.documentElement.classList.add('light-mode');
    else if (saved === 'dark') document.documentElement.classList.add('dark-mode');
  </script>
</head>
<body>
  <div class="terminal-window">
    <Header pathname={Astro.url.pathname} terminalPath={terminalPath} tagline={tagline} showHero={showHero} />
    <main class="main-content">
      <slot />
    </main>
    <Footer />
  </div>

  <script is:inline>
    const toggle = document.getElementById('theme-toggle');
    const root = document.documentElement;
    toggle?.addEventListener('click', () => {
      if (root.classList.contains('light-mode')) {
        root.classList.remove('light-mode');
        root.classList.add('dark-mode');
        localStorage.setItem('theme', 'dark');
      } else if (root.classList.contains('dark-mode')) {
        root.classList.remove('dark-mode');
        localStorage.removeItem('theme');
      } else {
        root.classList.add('light-mode');
        localStorage.setItem('theme', 'light');
      }
    });
  </script>
</body>
</html>
