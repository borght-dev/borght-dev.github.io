---
// Direction G · Engineering Log — Projects page
// Verbatim from personal-site-and-blog/project/site/direction-g-pages.jsx (GDirectionProjects)
import { PROJECTS, FONTS_HREF } from '../../../data/variants-data';

const G = {
  bg: '#0d0f12', panel: '#15181d', panelSoft: '#191d23',
  hairline: '#23262d', hairlineSoft: '#1a1d22',
  text: '#e6e7e9', text2: '#a8acb3', text3: '#6b6f76', muted: '#454a52',
  green: '#3ddc84', amber: '#ffb547', red: '#ff5a5f',
  blue: '#5fb3ff', mint: '#7dd3c0',
  mono: "'JetBrains Mono', ui-monospace, monospace",
  sans: "'Inter', sans-serif",
  serif: "'Fraunces', serif",
};

const navItems = ['INDEX', 'CHANGELOG', 'PROJECTS', 'NOW', 'CONTACT'];

type Archived = [string, string, string, string];
const archived: Archived[] = [
  ['plntr',  'Daily-planner web app', '2021—2023', 'sunset · superseded by paper'],
  ['kdraft', 'Markdown-first CMS',    '2020—2021', 'archived · ~600 commits'],
  ['mintly', 'Personal-finance ETL',  '2019—2020', 'archived · still useful'],
];
---

<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>Projects · G</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link rel="stylesheet" href={FONTS_HREF} />
  <style>
    html, body { margin: 0; padding: 0; background: #0d0f12; }
    a { cursor: pointer; }
    .g-root { width: 1280px; }
    .g-topbar { padding: 12px 32px; grid-template-columns: 1fr 1fr 1fr; }
    .g-topbar-mid { text-align: center; }
    .g-topbar-nav { gap: 22px; font-size: 11px; }
    .g-main { padding: 48px 32px 64px; }
    .g-h1 { font-size: 80px; }
    .g-proj-row { display: grid; grid-template-columns: 180px 1fr 220px; gap: 24px; }
    .g-arch-row { display: grid; grid-template-columns: 180px 1fr 220px; gap: 24px; }
    .g-footer { padding: 8px 32px; }
    @media (max-width: 767px) {
      .g-root { width: 100%; min-height: 0 !important; }
      .g-topbar { padding: 10px 16px !important; grid-template-columns: 1fr auto !important; gap: 8px !important; font-size: 10px !important; }
      .g-topbar-mid { display: none !important; }
      .g-topbar-nav { gap: 12px !important; font-size: 9.5px !important; flex-wrap: wrap; justify-content: flex-end !important; }
      .g-main { padding: 28px 18px 40px !important; }
      .g-h1 { font-size: 42px !important; line-height: 0.98 !important; }
      .g-proj-row { grid-template-columns: 1fr !important; gap: 12px !important; padding: 22px 0 !important; }
      .g-proj-row h2 { font-size: 26px !important; }
      .g-proj-row p { font-size: 14px !important; }
      .g-arch-row { grid-template-columns: 80px 1fr !important; gap: 10px !important; }
      .g-arch-row > span:nth-child(3) { grid-column: 1 / -1; text-align: left !important; font-size: 11px !important; color: #6b6f76 !important; }
      .g-footer { padding: 8px 16px !important; flex-wrap: wrap !important; gap: 4px !important; font-size: 9px !important; }
      .g-footer > span:nth-child(2) { display: none !important; }
    }
  </style>
</head>
<body>
<div class="g-root" style={{
  minHeight: '1860px', background: G.bg, color: G.text,
  fontFamily: G.mono, margin: '0 auto',
}}>
  <header class="g-topbar" style={{
    position: 'relative',
    borderBottom: `1px solid ${G.hairline}`,
    background: G.panel,
    display: 'grid', alignItems: 'center',
    color: G.text3, letterSpacing: '0.06em',
    fontFamily: G.mono,
  }}>
    <div style={{ display: 'flex', alignItems: 'center', gap: '14px' }}>
      <span style={{ width: '8px', height: '8px', borderRadius: '50%', background: G.green, boxShadow: `0 0 6px ${G.green}` }} />
      <span style={{ color: G.text }}>KOEN.NL · ENG-LOG</span>
      <span>· UPLINK <span style={{ color: G.green }}>OK</span></span>
    </div>
    <div class="g-topbar-mid" style={{ color: G.text2 }}>
      MISSION T+ <span style={{ color: G.amber }}>09y · 142d · 04:31:18</span>
    </div>
    <div class="g-topbar-nav" style={{ display: 'flex', justifyContent: 'flex-end' }}>
      {navItems.map((x) => {
        const active = x === 'PROJECTS';
        const href = x === 'CHANGELOG' ? '/variants/g/post' : x === 'PROJECTS' ? '/variants/g/projects' : '/variants/g/';
        return <a href={href} style={{ textDecoration: 'none', color: active ? G.amber : G.text2 }}>{x}</a>;
      })}
    </div>
  </header>

  <main class="g-main">
    <div style={{ fontSize: '11px', color: G.green, letterSpacing: '0.18em', marginBottom: '18px' }}>
      ▍ <span style={{ color: G.text }}>FILE</span> /var/projects/index &nbsp; <span style={{ color: G.text3 }}>· 3 deployments</span>
    </div>
    <h1 class="g-h1" style={{
      fontFamily: G.serif, fontWeight: 300,
      lineHeight: 0.96, letterSpacing: '-0.035em', margin: '0 0 22px',
    }}>
      Things <span style={{ fontStyle: 'italic', color: G.amber }}>currently</span><br />
      deployed.
    </h1>
    <p style={{ fontFamily: G.sans, fontSize: '16px', color: G.text2, lineHeight: 1.6, margin: '0 0 56px', maxWidth: '580px' }}>
      Three things, in increasing order of "you might actually want to use it".
      Each is a long-running process, not a sprint.
    </p>

    {PROJECTS.map((p, i) => {
      const c = p.statusKind === 'live' ? G.green : p.statusKind === 'wip' ? G.amber : G.mint;
      const uptime = p.statusKind === 'live' ? '99.9%' : p.statusKind === 'wip' ? 'staging' : 'idle';
      const pid = String(1340 + i * 17).padStart(4, '0');
      return (
        <article class="g-proj-row" style={{
          padding: '28px 0', borderTop: `1px solid ${G.hairline}`,
        }}>
          <div>
            <div style={{ fontSize: '10px', color: G.text3, letterSpacing: '0.14em', marginBottom: '6px' }}>
              PID {pid}
            </div>
            <div style={{ fontSize: '22px', color: G.amber, fontWeight: 600 }}>{p.code}</div>
            <div style={{
              marginTop: '12px', padding: '4px 10px', display: 'inline-flex',
              alignItems: 'center', gap: '6px',
              border: `1px solid ${c}`, color: c, fontSize: '10px', letterSpacing: '0.1em',
            }}>
              <span style={{ width: '5px', height: '5px', borderRadius: '50%', background: c }} />
              {p.status.toUpperCase()}
            </div>
          </div>
          <div>
            <h2 style={{
              fontFamily: G.serif, fontSize: '36px', fontWeight: 400,
              letterSpacing: '-0.02em', margin: '0 0 8px', color: G.text,
            }}>{p.name}</h2>
            <p style={{
              fontFamily: G.sans, fontSize: '15px', lineHeight: 1.65,
              color: G.text2, margin: '0 0 14px', maxWidth: '540px',
            }}>{p.blurb}</p>
            <div style={{ display: 'flex', gap: '6px', flexWrap: 'wrap' }}>
              {p.stack.map((s) => (
                <span style={{
                  fontSize: '10.5px', padding: '2px 8px',
                  border: `1px solid ${G.hairline}`, color: G.text2, letterSpacing: '0.04em',
                }}>{s}</span>
              ))}
            </div>
          </div>
          <div style={{
            background: G.panel, border: `1px solid ${G.hairline}`, padding: '14px',
          }}>
            <div style={{ fontSize: '10px', color: G.text3, letterSpacing: '0.14em', marginBottom: '8px' }}>METRICS</div>
            <div style={{ fontFamily: G.serif, fontSize: '30px', color: c, lineHeight: 1, fontWeight: 300 }}>{p.metric[0]}</div>
            <div style={{ fontSize: '11px', color: G.text3, marginTop: '4px' }}>{p.metric[1]}</div>
            <div style={{ marginTop: '14px', paddingTop: '12px', borderTop: `1px solid ${G.hairlineSoft}`, fontSize: '11px', color: G.text2 }}>
              <div>year · <span style={{ color: G.text }}>{p.year}</span></div>
              <div>uptime · <span style={{ color: c }}>{uptime}</span></div>
            </div>
          </div>
        </article>
      );
    })}

    <section style={{ marginTop: '56px', padding: '24px 0', borderTop: `2px solid ${G.hairline}` }}>
      <div style={{ fontSize: '11px', color: G.text3, letterSpacing: '0.18em', marginBottom: '18px' }}>
        ▍ ARCHIVED · stopped processes
      </div>
      {archived.map(([code, name, year, note]) => (
        <div class="g-arch-row" style={{
          padding: '14px 0', borderTop: `1px solid ${G.hairlineSoft}`,
          fontSize: '13px', color: G.text3,
        }}>
          <span style={{ color: G.muted }}>{code}</span>
          <span style={{ color: G.text2 }}>{name}</span>
          <span style={{ textAlign: 'right' }}>{year} · {note}</span>
        </div>
      ))}
    </section>
  </main>

  <footer class="g-footer" style={{
    background: G.panel, borderTop: `1px solid ${G.hairline}`,
    display: 'flex', justifyContent: 'space-between',
    fontSize: '10.5px', color: G.text3, letterSpacing: '0.05em',
  }}>
    <span>© 2026 KOEN VAN DER BORGHT · NL</span>
    <span>3 ACTIVE · 3 ARCHIVED</span>
    <span set:html={'{ HZ: 60 }'} />
  </footer>
</div>
</body>
</html>
