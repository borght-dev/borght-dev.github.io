---
interface Props {
  pathname: string;
}
const { pathname } = Astro.props;

const links = [
  { href: '/legacy/blog/',     label: '~/blog',     match: '/legacy/blog',     mobile: true  },
  { href: '/legacy/series/',   label: '~/series',   match: '/legacy/series',   mobile: true  },
  { href: '/legacy/projects/', label: '~/projects', match: '/legacy/projects', mobile: false },
  { href: '/legacy/about/',    label: '~/about',    match: '/legacy/about',    mobile: false },
];

const isActive = (m: string) => pathname.startsWith(m);
---

<header class="topbar">
  <div class="topbar-inner">
    <a href="/legacy/" class="topbar-prompt" aria-label="home">
      <span class="pulse-dot" aria-hidden="true"></span>
      <span><span class="who">koen</span><span class="at">@</span><span class="who">vanderborght</span><span style="color:var(--ink-mute)">:~$</span></span>
    </a>
    <nav class="topbar-nav" aria-label="primary">
      { links.map(l => (
        <a href={l.href}
           class={`${isActive(l.match) ? 'active' : ''} ${l.mobile ? '' : 'hide-mobile'}`}>
          {l.label}
        </a>
      )) }
      <button id="theme-toggle" class="topbar-toggle" aria-label="Toggle theme">◐</button>
    </nav>
  </div>
</header>
