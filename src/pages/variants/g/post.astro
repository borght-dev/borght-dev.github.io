---
// Direction G · Engineering Log — Sample post page (changelog entry)
// Verbatim from personal-site-and-blog/project/site/direction-g-pages.jsx (GDirectionPost)
import { POSTS, FONTS_HREF } from '../../../data/variants-data';

const G = {
  bg: '#0d0f12', panel: '#15181d', panelSoft: '#191d23',
  hairline: '#23262d', hairlineSoft: '#1a1d22',
  text: '#e6e7e9', text2: '#a8acb3', text3: '#6b6f76', muted: '#454a52',
  green: '#3ddc84', amber: '#ffb547', red: '#ff5a5f',
  blue: '#5fb3ff', mint: '#7dd3c0',
  mono: "'JetBrains Mono', ui-monospace, monospace",
  sans: "'Inter', sans-serif",
  serif: "'Fraunces', serif",
};

const navItems = ['INDEX', 'CHANGELOG', 'PROJECTS', 'NOW', 'CONTACT'];

type Line = [string, string, string];
const lines: Line[] = [
  ['+', 'feat', 'invariant inference for Activity model'],
  ['+', 'feat', 'parity harness ./parity ./legacy ./new'],
  ['+', 'docs', 'rebuilt domain glossary (412 → 89 entries)'],
  ['~', 'fix',  'timezone drift in scheduling window'],
  ['-', 'rm',   'shared/utils/dateHelpers.ts (-340 LOC)'],
  ['+', 'test', '83 new behaviour tests (7,200 → 7,283)'],
];

const meta: Array<[string, string]> = [
  ['DURATION', '6 weeks'],
  ['LOC Δ',    '+18.4k −24.1k'],
  ['TESTS',    '7,283 / 7,283'],
  ['PARITY',   '99.7%'],
];

// Code block rendered via set:html so the `$` and quotes don't fight the JSX parser.
const codeBlockHtml =
  `<span style="color:${G.text3}"># 1. open the legacy file</span>\n` +
  `<span style="color:${G.green}">$</span> nvim legacy/Activity.cs\n` +
  `<span style="color:${G.text3}"># 2. ask claude to model it</span>\n` +
  `<span style="color:${G.green}">$</span> claude <span style="color:${G.amber}">"what invariants does this enforce?"</span>\n` +
  `<span style="color:${G.text3}"># 3. write the new version with tests</span>\n` +
  `<span style="color:${G.green}">$</span> claude /implement Activity --tests\n` +
  `<span style="color:${G.text3}"># 4. diff against legacy behaviour</span>\n` +
  `<span style="color:${G.green}">$</span> ./parity ./legacy ./new`;

type TocItem = [string | null, string];
const toc: TocItem[] = [
  ['active', 'The shape of the work'],
  [null, 'Commit notes'],
  [null, 'What worked'],
  [null, 'What I would not do again'],
  [null, 'Where I am now'],
];
---

<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>v5.15.0 · Rebuilding a 9-year-old codebase · G</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link rel="stylesheet" href={FONTS_HREF} />
  <style>
    html, body { margin: 0; padding: 0; background: #0d0f12; }
    a { cursor: pointer; }
    .g-root { width: 1280px; }
    .g-topbar { padding: 12px 32px; grid-template-columns: 1fr 1fr 1fr; }
    .g-topbar-mid { text-align: center; }
    .g-topbar-nav { gap: 22px; font-size: 11px; }
    .g-main { padding: 40px 32px 0; display: grid; grid-template-columns: 1fr 320px; gap: 40px; }
    .g-h1 { font-size: 64px; }
    .g-rail { position: sticky; top: 32px; align-self: flex-start; }
    .g-meta-grid { display: grid; grid-template-columns: repeat(4, 1fr); }
    .g-pn-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 12px; }
    .g-footer { padding: 8px 32px; }
    @media (max-width: 767px) {
      .g-root { width: 100%; min-height: 0 !important; }
      .g-topbar { padding: 10px 16px !important; grid-template-columns: 1fr auto !important; gap: 8px !important; font-size: 10px !important; }
      .g-topbar-mid { display: none !important; }
      .g-topbar-nav { gap: 12px !important; font-size: 9.5px !important; flex-wrap: wrap; justify-content: flex-end !important; }
      .g-main { padding: 26px 18px 0 !important; grid-template-columns: 1fr !important; gap: 28px !important; }
      .g-h1 { font-size: 36px !important; line-height: 1.02 !important; }
      .g-meta-grid { grid-template-columns: 1fr 1fr !important; }
      .g-meta-grid > div { border-right: none !important; border-bottom: 1px solid #23262d; }
      .g-meta-grid > div:nth-child(odd) { border-right: 1px solid #23262d !important; }
      .g-rail { position: static !important; top: auto !important; }
      .g-prose { font-size: 15px !important; }
      .g-prose pre { font-size: 11.5px !important; padding: 10px 14px !important; }
      .g-pn-grid { grid-template-columns: 1fr !important; }
      .g-footer { padding: 8px 16px !important; flex-wrap: wrap !important; gap: 4px !important; font-size: 9px !important; }
      .g-footer > span:nth-child(2) { display: none !important; }
    }
  </style>
</head>
<body>
<div class="g-root" style={{
  minHeight: '1860px', background: G.bg, color: G.text,
  fontFamily: G.mono, margin: '0 auto',
}}>
  <header class="g-topbar" style={{
    position: 'relative',
    borderBottom: `1px solid ${G.hairline}`,
    background: G.panel,
    display: 'grid', alignItems: 'center',
    color: G.text3, letterSpacing: '0.06em',
    fontFamily: G.mono,
  }}>
    <div style={{ display: 'flex', alignItems: 'center', gap: '14px' }}>
      <span style={{ width: '8px', height: '8px', borderRadius: '50%', background: G.green, boxShadow: `0 0 6px ${G.green}` }} />
      <span style={{ color: G.text }}>KOEN.NL · ENG-LOG</span>
      <span>· UPLINK <span style={{ color: G.green }}>OK</span></span>
    </div>
    <div class="g-topbar-mid" style={{ color: G.text2 }}>
      MISSION T+ <span style={{ color: G.amber }}>09y · 142d · 04:31:18</span>
    </div>
    <div class="g-topbar-nav" style={{ display: 'flex', justifyContent: 'flex-end' }}>
      {navItems.map((x) => {
        const active = x === 'CHANGELOG';
        const href = x === 'CHANGELOG' ? '/variants/g/post' : x === 'PROJECTS' ? '/variants/g/projects' : '/variants/g/';
        return <a href={href} style={{ textDecoration: 'none', color: active ? G.amber : G.text2 }}>{x}</a>;
      })}
    </div>
  </header>

  <main class="g-main">
    <article>
      <div style={{ fontSize: '11px', color: G.text3, marginBottom: '14px' }}>
        <a href="/variants/g/" style={{ color: G.amber }}>/changelog</a> &nbsp;›&nbsp; v5.15.0
      </div>

      <div style={{
        display: 'inline-flex', gap: '10px', alignItems: 'center', marginBottom: '18px',
        padding: '4px 12px', border: `1px solid ${G.amber}`,
        color: G.amber, fontSize: '10px', letterSpacing: '0.14em',
      }}>
        <span style={{ width: '6px', height: '6px', borderRadius: '50%', background: G.amber }} />
        MAJOR · v5.15.0 · 2026-04-18
      </div>

      <h1 class="g-h1" style={{
        fontFamily: G.serif, fontWeight: 300,
        lineHeight: 0.98, letterSpacing: '-0.03em', margin: '0 0 18px',
        color: G.text,
      }}>
        Rebuilding a <span style={{ fontStyle: 'italic', color: G.amber }}>9-year-old</span><br />
        codebase with Claude Code.
      </h1>
      <p style={{
        fontFamily: G.sans, fontSize: '17px', lineHeight: 1.6,
        color: G.text2, margin: '0 0 28px', maxWidth: '600px',
      }}>
        Six weeks, one developer, one model. What survived contact with the
        real domain — and what I would not do again.
      </p>

      <div class="g-meta-grid" style={{
        border: `1px solid ${G.hairline}`, marginBottom: '36px',
      }}>
        {meta.map(([k, v], i) => (
          <div style={{
            padding: '12px 14px',
            borderRight: i < 3 ? `1px solid ${G.hairline}` : 'none',
          }}>
            <div style={{ fontSize: '10px', color: G.text3, letterSpacing: '0.14em' }}>{k}</div>
            <div style={{ fontSize: '16px', color: G.text, marginTop: '2px' }}>{v}</div>
          </div>
        ))}
      </div>

      <div style={{ fontSize: '11px', color: G.green, letterSpacing: '0.18em', marginBottom: '12px' }}>
        ▍ <span style={{ color: G.text }}>COMMIT NOTES</span>
      </div>
      <div style={{
        background: G.panel, border: `1px solid ${G.hairline}`,
        padding: '14px 18px', marginBottom: '28px', fontSize: '13px',
      }}>
        {lines.map(([sig, kind, msg], i) => {
          const c = sig === '+' ? G.green : sig === '-' ? G.red : G.amber;
          return (
            <div style={{
              display: 'grid', gridTemplateColumns: '20px 70px 1fr',
              padding: '5px 0', borderTop: i ? `1px dashed ${G.hairlineSoft}` : 'none',
            }}>
              <span style={{ color: c, fontWeight: 700 }}>{sig}</span>
              <span style={{ color: G.text3 }}>{kind}</span>
              <span style={{ color: G.text }}>{msg}</span>
            </div>
          );
        })}
      </div>

      <div class="g-prose" style={{ fontFamily: G.sans, fontSize: '16px', lineHeight: 1.75, color: G.text }}>
        <h2 style={{
          fontFamily: G.mono, fontSize: '13px', color: G.amber,
          letterSpacing: '0.18em', margin: '12px 0 14px',
        }}>▍ THE SHAPE OF THE WORK</h2>
        <p style={{ margin: '0 0 18px', color: G.text2 }}>
          The codebase I rebuilt is nine years old, written by ten different
          people, and runs in production at every customer my employer has.
          The kind of codebase with a <code style={{ background: G.panel, padding: '1px 6px', fontFamily: G.mono, fontSize: '13px', color: G.amber }}>shared/</code> folder
          with 412 files in it.
        </p>
        <p style={{ margin: '0 0 18px', color: G.text2 }}>
          For six weeks I ran roughly the same loop, every morning:
        </p>

        <pre style={{
          margin: '0 0 22px', padding: '14px 18px',
          background: G.panel, border: `1px solid ${G.hairline}`,
          fontFamily: G.mono, fontSize: '13px', color: G.text, lineHeight: 1.7,
          overflow: 'auto',
        }} set:html={codeBlockHtml} />

        <div style={{
          padding: '16px 20px', borderLeft: `3px solid ${G.amber}`,
          background: G.panel, margin: '0 0 22px',
          fontFamily: G.serif, fontSize: '19px', fontStyle: 'italic',
          lineHeight: 1.5, color: G.text,
        }}>
          "Bugs customers depend on are features. Bugs customers don't notice
          are technical debt. The model can't tell them apart; you have to."
        </div>

        <h2 style={{
          fontFamily: G.mono, fontSize: '13px', color: G.amber,
          letterSpacing: '0.18em', margin: '28px 0 14px',
        }}>▍ WHAT WORKED</h2>
        <ul style={{ paddingLeft: '22px', margin: '0 0 24px', color: G.text2 }}>
          <li style={{ marginBottom: '6px' }}>Explaining the <em>domain</em>, not the code, to the model.</li>
          <li style={{ marginBottom: '6px' }}>Treating the legacy system as the spec.</li>
          <li style={{ marginBottom: '6px' }}>Tests <strong style={{ color: G.text }}>first</strong>, then implementation.</li>
          <li>Owning the architecture; delegating the fingertips.</li>
        </ul>

        <h2 style={{
          fontFamily: G.mono, fontSize: '13px', color: G.amber,
          letterSpacing: '0.18em', margin: '28px 0 14px',
        }}>▍ WHAT I WOULD NOT DO AGAIN</h2>
        <p style={{ margin: '0 0 18px', color: G.text2 }}>
          I would not let the model invent table names. I would not skip the
          parity step "just for the easy module". The cost of context drift
          is the cost of a day.
        </p>
      </div>

      <div class="g-pn-grid" style={{
        marginTop: '40px', paddingTop: '24px', borderTop: `1px solid ${G.hairline}`,
        fontFamily: G.mono, fontSize: '12px',
      }}>
        <div style={{ padding: '14px 18px', background: G.panel, border: `1px solid ${G.hairline}` }}>
          <div style={{ color: G.text3, fontSize: '10px', letterSpacing: '0.14em', marginBottom: '4px' }}>← PREVIOUS</div>
          <div style={{ color: G.text }}>v5.14.0 · BorgDock: the tool I built</div>
          <div style={{ color: G.text3, fontSize: '11px', marginTop: '2px' }}>2026-03-27 · 8 min</div>
        </div>
        <div style={{ padding: '14px 18px', background: G.panel, border: `1px solid ${G.hairline}` }}>
          <div style={{ color: G.text3, fontSize: '10px', letterSpacing: '0.14em', marginBottom: '4px', textAlign: 'right' }}>NEXT →</div>
          <div style={{ color: G.muted, textAlign: 'right' }}>(latest entry)</div>
          <div style={{ color: G.text3, fontSize: '11px', marginTop: '2px', textAlign: 'right' }}>more soon</div>
        </div>
      </div>
    </article>

    <aside class="g-rail" style={{ position: 'sticky', top: '32px', alignSelf: 'flex-start' }}>
      <div style={{ fontSize: '11px', color: G.green, letterSpacing: '0.18em', marginBottom: '14px' }}>
        ▍ <span style={{ color: G.text }}>TOC</span>
      </div>
      <div style={{ background: G.panel, border: `1px solid ${G.hairline}`, padding: '14px' }}>
        {toc.map(([s, label], i) => {
          const active = s === 'active';
          return (
            <div style={{
              padding: '6px 0', fontSize: '12px',
              borderLeft: active ? `2px solid ${G.amber}` : '2px solid transparent',
              paddingLeft: '10px',
              color: active ? G.text : G.text2,
            }}>{i + 1}. {label}</div>
          );
        })}
      </div>

      <div style={{ fontSize: '11px', color: G.amber, letterSpacing: '0.18em', margin: '24px 0 12px' }}>
        ▍ <span style={{ color: G.text }}>RELATED</span>
      </div>
      {POSTS.slice(1, 4).map((p, i) => (
        <div style={{
          padding: '10px 0', borderTop: `1px solid ${G.hairline}`, fontSize: '12px',
        }}>
          <div style={{ color: G.amber, fontSize: '10.5px' }}>v{POSTS.length - i - 1}.{(POSTS.length - i - 1) * 3}.0 · {p.date}</div>
          <div style={{ color: G.text, marginTop: '2px', lineHeight: 1.4 }}>{p.title}</div>
        </div>
      ))}

      <div style={{ fontSize: '11px', color: G.amber, letterSpacing: '0.18em', margin: '24px 0 12px' }}>
        ▍ <span style={{ color: G.text }}>SUBSCRIBE</span>
      </div>
      <div style={{ fontSize: '12px', color: G.text2, lineHeight: 1.8 }}>
        <div>$ rss <span style={{ color: G.text }}>/feed.xml</span></div>
        <div>$ email <span style={{ color: G.text }}>list</span></div>
        <div>$ gh follow <span style={{ color: G.text }}>koenvdborght</span></div>
      </div>
    </aside>
  </main>

  <footer class="g-footer" style={{
    marginTop: '56px',
    background: G.panel, borderTop: `1px solid ${G.hairline}`,
    display: 'flex', justifyContent: 'space-between',
    fontSize: '10.5px', color: G.text3, letterSpacing: '0.05em',
  }}>
    <span>© 2026 KOEN VAN DER BORGHT · NL</span>
    <span>JETBRAINS MONO · FRAUNCES · INTER</span>
    <span set:html={'{ HZ: 60 · CPU: 0.2% · MEM: 64 KB }'} />
  </footer>
</div>
</body>
</html>
