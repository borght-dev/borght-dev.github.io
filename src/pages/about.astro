---
// D · /about — renders content/pages/about.md
import DLayout from '../layouts/DLayout.astro';
import { getEntry, render } from 'astro:content';

const entry = await getEntry('pages', 'about');
const { Content } = entry ? await render(entry) : { Content: null };

const title = entry?.data.title ?? 'About';
const description = entry?.data.description;
---

<DLayout title={title} description={description} active={null}>
  <div style="font-family: var(--d-mono); font-size: 12px; color: var(--d-accent); margin-bottom: 28px;"># about.md</div>

  <h1 style="font-family: var(--d-serif); font-weight: 400; font-size: 48px; line-height: 1.08; letter-spacing: -0.025em; margin: 0 0 36px;" class="d-h1">
    About <span style="font-style: italic; color: var(--d-accent);">me</span>.
  </h1>

  <div class="d-prose">
    {Content ? <Content /> : <p>No about content yet.</p>}
  </div>
</DLayout>

<style>
  @media (max-width: 767px) {
    h1.d-h1 { font-size: 32px !important; }
  }
</style>
