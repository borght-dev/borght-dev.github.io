---
import '../styles/global.css';
import Topbar from '../components/Topbar.astro';
import Footer from '../components/Footer.astro';

interface Props {
  title: string;
  description?: string;
  /** Set false on the home page to hide the slim top bar (the hero contains its own prompt). */
  showTopbar?: boolean;
}

const {
  title,
  description = 'Senior dev at Gomocha, building developer tools and writing about AI-native engineering.',
  showTopbar = true,
} = Astro.props;

const fullTitle = title === 'Koen van der Borght' ? title : `${title} · koen.vanderborght`;
const canonical = new URL(Astro.url.pathname, Astro.site).toString();
---

<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
  <meta name="theme-color" content="#FAFBFC" media="(prefers-color-scheme: light)" />
  <meta name="theme-color" content="#0A0E1A" media="(prefers-color-scheme: dark)" />
  <meta name="description" content={description} />
  <meta name="generator" content={Astro.generator} />
  <link rel="icon" type="image/x-icon" href="/favicon.ico" />
  <link rel="canonical" href={canonical} />
  <link rel="alternate" type="application/rss+xml" href="/rss.xml" title="Koen van der Borght" />

  <meta property="og:type" content="website" />
  <meta property="og:url" content={canonical} />
  <meta property="og:title" content={fullTitle} />
  <meta property="og:description" content={description} />
  <meta property="twitter:card" content="summary_large_image" />
  <meta property="twitter:title" content={fullTitle} />
  <meta property="twitter:description" content={description} />

  <title>{fullTitle}</title>

  <script is:inline>
    const saved = localStorage.getItem('theme');
    if (saved === 'light') document.documentElement.classList.add('light-mode');
    else if (saved === 'dark') document.documentElement.classList.add('dark-mode');
  </script>
</head>
<body>
  { showTopbar && <Topbar pathname={Astro.url.pathname} /> }
  <slot />
  <Footer />

  <script is:inline>
    const toggle = document.getElementById('theme-toggle');
    const root = document.documentElement;
    toggle?.addEventListener('click', () => {
      if (root.classList.contains('light-mode')) {
        root.classList.remove('light-mode');
        root.classList.add('dark-mode');
        localStorage.setItem('theme', 'dark');
      } else if (root.classList.contains('dark-mode')) {
        root.classList.remove('dark-mode');
        localStorage.removeItem('theme');
      } else {
        root.classList.add('light-mode');
        localStorage.setItem('theme', 'light');
      }
    });
  </script>
</body>
</html>
