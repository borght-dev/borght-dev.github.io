---
// Direction E · IDE Theme — Project page (borgdock.json)
// Verbatim from personal-site-and-blog/project/site/direction-e-pages.jsx (EDirectionProject)
import { POSTS, PROJECTS, FONTS_HREF } from '../../../data/variants-data';

const E = {
  bg: '#1e1e2e', panel: '#181825', sidebar: '#11111b',
  hairline: '#313244', hairlineSoft: '#1e1e2e',
  text: '#cdd6f4', text2: '#a6adc8', text3: '#7f849c', muted: '#585b70',
  red: '#f38ba8', green: '#a6e3a1', yellow: '#f9e2af',
  blue: '#89b4fa', purple: '#cba6f7', orange: '#fab387', cyan: '#94e2d5',
  mono: "'JetBrains Mono', ui-monospace, monospace",
  sans: "'Inter', sans-serif",
};

const lineNumbers = Array.from({ length: 70 }, (_, i) => i + 1);

const treeActive = 'BD';

const modes: Array<[string, string, string]> = [
  ['Sidebar',         'always-on, 320px',     E.purple],
  ['Floating Island', 'auto-hides on idle',   E.cyan],
  ['Glass Capsule',   'translucent, glanceable', E.green],
  ['Liquid Morph',    'morphs to context',    E.orange],
];

// JSON snippet rendered via set:html so literal { and } don't trip the JSX parser.
const jsonHtml =
  `<span style="color:${E.text}">{</span>\n` +
  `  <span style="color:${E.cyan}">"name"</span>: <span style="color:${E.green}">"BorgDock"</span>,\n` +
  `  <span style="color:${E.cyan}">"tagline"</span>: <span style="color:${E.green}">"the dock that drafts itself into your day."</span>,\n` +
  `  <span style="color:${E.cyan}">"status"</span>: <span style="color:${E.green}">"in daily use"</span>,\n` +
  `  <span style="color:${E.cyan}">"version"</span>: <span style="color:${E.green}">"0.9.2"</span>,\n` +
  `  <span style="color:${E.cyan}">"started"</span>: <span style="color:${E.yellow}">2025</span>,\n` +
  `  <span style="color:${E.cyan}">"author"</span>: <span style="color:${E.green}">"koen"</span>,\n` +
  `  <span style="color:${E.cyan}">"links"</span>: <span style="color:${E.text}">{</span>\n` +
  `    <span style="color:${E.cyan}">"site"</span>: <span style="color:${E.green}">"https://borgdock.dev"</span>,\n` +
  `    <span style="color:${E.cyan}">"github"</span>: <span style="color:${E.green}">"github.com/koenvdborght/borgdock"</span>\n` +
  `  <span style="color:${E.text}">}</span>,\n` +
  `  <span style="color:${E.cyan}">"stack"</span>: [<span style="color:${E.green}">"Tauri"</span>, <span style="color:${E.green}">"Rust"</span>, <span style="color:${E.green}">"React"</span>, <span style="color:${E.green}">"TypeScript"</span>],\n` +
  `  <span style="color:${E.cyan}">"metrics"</span>: <span style="color:${E.text}">{</span>\n` +
  `    <span style="color:${E.cyan}">"footprint"</span>: <span style="color:${E.green}">"22 MB"</span>,\n` +
  `    <span style="color:${E.cyan}">"commits"</span>: <span style="color:${E.yellow}">2412</span>,\n` +
  `    <span style="color:${E.cyan}">"daily_users"</span>: <span style="color:${E.yellow}">1</span> <span style="color:${E.text3}">// me</span>\n` +
  `  <span style="color:${E.text}">}</span>\n` +
  `<span style="color:${E.text}">}</span>`;
---

<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>borgdock.json · E</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link rel="stylesheet" href={FONTS_HREF} />
  <style>
    html, body { margin: 0; padding: 0; background: #1e1e2e; }
    a { cursor: pointer; }
    .e-root { width: 1280px; }
    .e-shell { display: grid; grid-template-columns: 52px 240px 1fr; min-height: 1820px; }
    .e-titlebar-text { margin-left: 24px; }
    .e-titlebar-keys { margin-left: auto; }
    .e-tab-extra { display: flex; }
    .e-line-gutter { width: 54px; padding: 20px 14px 20px 0; font-size: 12px; }
    .e-editor { padding: 20px 32px; font-size: 13px; }
    .e-modes { display: grid; grid-template-columns: repeat(4, 1fr); gap: 8px; }
    .e-status-l, .e-status-r { gap: 16px; }
    @media (max-width: 767px) {
      .e-root { width: 100%; min-height: 0 !important; }
      .e-shell { grid-template-columns: 32px 1fr !important; min-height: 0 !important; }
      .e-activity, .e-tree { display: none !important; }
      .e-titlebar-text { margin-left: 12px !important; font-size: 10px !important; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
      .e-titlebar-keys { display: none !important; }
      .e-tab-extra { display: none !important; }
      .e-tab-active { padding: 6px 12px !important; font-size: 11px !important; }
      .e-breadcrumb { padding: 6px 12px !important; font-size: 10.5px !important; }
      .e-line-gutter { width: 32px !important; padding: 14px 6px 14px 0 !important; font-size: 10.5px !important; }
      .e-editor { padding: 14px 14px !important; font-size: 12px !important; }
      .e-editor pre { font-size: 11px !important; padding: 8px 10px !important; overflow-x: auto; }
      .e-modes { grid-template-columns: 1fr 1fr !important; }
      .e-status-l, .e-status-r { gap: 8px !important; font-size: 9px !important; }
      .e-status-r > span:nth-child(2), .e-status-r > span:nth-child(3) { display: none !important; }
    }
  </style>
</head>
<body>
<div class="e-root" style={{
  minHeight: '1860px', background: E.bg, color: E.text,
  fontFamily: E.sans, position: 'relative', margin: '0 auto',
}}>
  <div style={{
    padding: '8px 14px', borderBottom: `1px solid ${E.hairline}`,
    background: E.sidebar, display: 'flex', alignItems: 'center',
    fontFamily: E.mono, fontSize: '11px', color: E.text3, gap: '8px',
  }}>
    <span style={{ display: 'flex', gap: '6px' }}>
      <span style={{ width: '11px', height: '11px', borderRadius: '50%', background: '#f38ba8' }} />
      <span style={{ width: '11px', height: '11px', borderRadius: '50%', background: '#f9e2af' }} />
      <span style={{ width: '11px', height: '11px', borderRadius: '50%', background: '#a6e3a1' }} />
    </span>
    <span class="e-titlebar-text">koenvdborght.nl — borgdock.json — vscode-mocha</span>
    <span class="e-titlebar-keys">⌘K · ⌘P · ^`</span>
  </div>

  <div class="e-shell">
    <aside class="e-activity" style={{
      background: E.sidebar, borderRight: `1px solid ${E.hairline}`,
      padding: '12px 0', display: 'flex', flexDirection: 'column', alignItems: 'center', gap: '12px',
    }}>
      {['📁', '🔍', '✎', '◔', '⚙'].map((i, idx) => {
        const on = idx === 0;
        return (
          <div style={{
            width: '36px', height: '36px', borderRadius: '6px',
            display: 'flex', alignItems: 'center', justifyContent: 'center',
            background: on ? 'rgba(203,166,247,0.1)' : 'transparent',
            borderLeft: on ? `2px solid ${E.purple}` : '2px solid transparent',
            fontFamily: E.mono, fontSize: '14px', color: on ? E.text : E.text3,
          }}>{i}</div>
        );
      })}
    </aside>

    <aside class="e-tree" style={{
      background: E.panel, borderRight: `1px solid ${E.hairline}`, padding: '14px 0',
    }}>
      <div style={{
        padding: '0 14px 10px', fontFamily: E.mono, fontSize: '10px',
        color: E.text3, letterSpacing: '0.1em', textTransform: 'uppercase',
      }}>EXPLORER</div>

      <div style={{ display: 'flex', alignItems: 'center', gap: '6px', padding: '4px 12px', fontFamily: E.mono, fontSize: '11.5px', color: E.text }}>
        <span style={{ color: E.text, fontSize: '10px', width: '10px' }}>▾</span><span>koenvdborght</span>
      </div>
      <div style={{ display: 'flex', alignItems: 'center', gap: '6px', padding: '4px 12px 4px 26px', fontFamily: E.mono, fontSize: '11.5px', color: E.text2 }}>
        <span style={{ color: E.blue, fontSize: '10px', width: '10px' }}>▾</span><span>posts</span>
      </div>
      {POSTS.map((p) => (
        <div style={{
          display: 'flex', alignItems: 'center', gap: '6px', padding: '4px 12px 4px 40px',
          fontFamily: E.mono, fontSize: '11.5px', color: E.text2,
        }}>
          <span style={{ color: E.text3, fontSize: '10px', width: '10px' }}>◧</span>
          <span>{p.title.toLowerCase().replace(/[^a-z0-9]+/g, '-').slice(0, 28)}.md</span>
        </div>
      ))}

      <div style={{ display: 'flex', alignItems: 'center', gap: '6px', padding: '4px 12px 4px 26px', fontFamily: E.mono, fontSize: '11.5px', color: E.text2 }}>
        <span style={{ color: E.blue, fontSize: '10px', width: '10px' }}>▾</span><span>projects</span>
      </div>
      {PROJECTS.map((p) => {
        const active = treeActive === p.code;
        return (
          <div style={{
            display: 'flex', alignItems: 'center', gap: '6px', padding: '4px 12px 4px 40px',
            fontFamily: E.mono, fontSize: '11.5px',
            color: active ? E.text : E.text2,
            background: active ? 'rgba(203,166,247,0.1)' : 'transparent',
          }}>
            <span style={{ color: E.yellow, fontSize: '10px', width: '10px' }}>◧</span>
            <span>{p.name.toLowerCase().replace(/\s/g, '-')}.json</span>
          </div>
        );
      })}

      <div style={{ display: 'flex', alignItems: 'center', gap: '6px', padding: '4px 12px 4px 26px', fontFamily: E.mono, fontSize: '11.5px', color: E.text2 }}>
        <span style={{ color: E.blue, fontSize: '10px', width: '10px' }}>▾</span><span>setup</span>
      </div>
      <div style={{ display: 'flex', alignItems: 'center', gap: '6px', padding: '4px 12px 4px 40px', fontFamily: E.mono, fontSize: '11.5px', color: E.text2 }}>
        <span style={{ color: E.orange, fontSize: '10px', width: '10px' }}>◧</span><span>editor.toml</span>
      </div>
      <div style={{ display: 'flex', alignItems: 'center', gap: '6px', padding: '4px 12px 4px 40px', fontFamily: E.mono, fontSize: '11.5px', color: E.text2 }}>
        <span style={{ color: E.orange, fontSize: '10px', width: '10px' }}>◧</span><span>terminal.toml</span>
      </div>
      <div style={{ display: 'flex', alignItems: 'center', gap: '6px', padding: '4px 12px 4px 40px', fontFamily: E.mono, fontSize: '11.5px', color: E.text2 }}>
        <span style={{ color: E.orange, fontSize: '10px', width: '10px' }}>◧</span><span>keyboard.toml</span>
      </div>
      <div style={{ display: 'flex', alignItems: 'center', gap: '6px', padding: '4px 12px 4px 26px', fontFamily: E.mono, fontSize: '11.5px', color: E.text2 }}>
        <span style={{ color: E.text3, fontSize: '10px', width: '10px' }}>◧</span><span>about.md</span>
      </div>
      <div style={{ display: 'flex', alignItems: 'center', gap: '6px', padding: '4px 12px 4px 26px', fontFamily: E.mono, fontSize: '11.5px', color: E.text2 }}>
        <span style={{ color: E.text3, fontSize: '10px', width: '10px' }}>◧</span><span>now.md</span>
      </div>
      <div style={{ display: 'flex', alignItems: 'center', gap: '6px', padding: '4px 12px 4px 26px', fontFamily: E.mono, fontSize: '11.5px', color: E.text2 }}>
        <span style={{ color: E.text3, fontSize: '10px', width: '10px' }}>◧</span><span>uses.md</span>
      </div>
      <div style={{ display: 'flex', alignItems: 'center', gap: '6px', padding: '4px 12px 4px 26px', fontFamily: E.mono, fontSize: '11.5px', color: E.text2 }}>
        <span style={{ color: E.text3, fontSize: '10px', width: '10px' }}>◧</span><span>readme.md</span>
      </div>
      <div style={{ display: 'flex', alignItems: 'center', gap: '6px', padding: '4px 12px 4px 26px', fontFamily: E.mono, fontSize: '11.5px', color: E.text2 }}>
        <span style={{ color: E.muted, fontSize: '10px', width: '10px' }}>◧</span><span>.gitignore</span>
      </div>
      <div style={{ display: 'flex', alignItems: 'center', gap: '6px', padding: '4px 12px 4px 26px', fontFamily: E.mono, fontSize: '11.5px', color: E.text2 }}>
        <span style={{ color: E.yellow, fontSize: '10px', width: '10px' }}>◧</span><span>package.json</span>
      </div>
    </aside>

    <main style={{ display: 'flex', flexDirection: 'column' }}>
      <div style={{ display: 'flex', background: E.panel, borderBottom: `1px solid ${E.hairline}` }}>
        <div class="e-tab-extra" style={{
          display: 'flex', alignItems: 'center', gap: '8px', padding: '8px 14px',
          borderRight: `1px solid ${E.hairline}`, background: E.panel,
          borderTop: '2px solid transparent', fontFamily: E.mono, fontSize: '11.5px', color: E.text3,
        }}>
          <span style={{ color: E.blue }}>●</span>
          <span>about<span style={{ color: E.muted }}>.md</span></span>
          <span style={{ marginLeft: '8px', color: E.muted }}>×</span>
        </div>
        <div class="e-tab-extra" style={{
          display: 'flex', alignItems: 'center', gap: '8px', padding: '8px 14px',
          borderRight: `1px solid ${E.hairline}`, background: E.panel,
          borderTop: '2px solid transparent', fontFamily: E.mono, fontSize: '11.5px', color: E.text3,
        }}>
          <span style={{ color: E.blue }}>●</span>
          <span>rebuilding-9-year-codebase<span style={{ color: E.muted }}>.md</span></span>
          <span style={{ marginLeft: '8px', color: E.muted }}>×</span>
        </div>
        <div class="e-tab-active" style={{
          display: 'flex', alignItems: 'center', gap: '8px', padding: '8px 14px',
          borderRight: `1px solid ${E.hairline}`, background: E.bg,
          borderTop: `2px solid ${E.purple}`, borderBottom: `1px solid ${E.bg}`,
          fontFamily: E.mono, fontSize: '11.5px', color: E.text,
        }}>
          <span style={{ color: E.yellow }}>●</span>
          <span>borgdock<span style={{ color: E.muted }}>.json</span></span>
          <span style={{ marginLeft: '8px', color: E.muted }}>×</span>
        </div>
      </div>
      <div class="e-breadcrumb" style={{
        padding: '6px 16px', borderBottom: `1px solid ${E.hairline}`,
        fontFamily: E.mono, fontSize: '11px', color: E.text3,
      }}>
        <span style={{ color: E.text3 }}>koenvdborght</span>
        <span style={{ margin: '0 6px' }}>›</span>
        <span style={{ color: E.text3 }}>projects</span>
        <span style={{ margin: '0 6px' }}>›</span>
        <span style={{ color: E.purple }}>borgdock.json</span>
      </div>

      <div class="e-pane" style={{ display: 'grid', gridTemplateColumns: '54px 1fr', flex: 1 }}>
        <div class="e-line-gutter" style={{
          textAlign: 'right',
          fontFamily: E.mono, color: E.muted,
          borderRight: `1px solid ${E.hairlineSoft}`, userSelect: 'none', lineHeight: '1.7em',
        }}>
          {lineNumbers.map((n) => <div>{n}</div>)}
        </div>
        <div class="e-editor" style={{ fontFamily: E.mono, lineHeight: 1.7 }}>
          <pre style={{ margin: 0, color: E.text, fontFamily: E.mono, fontSize: '13px', lineHeight: 1.7 }} set:html={jsonHtml} />

          <div style={{ marginTop: '24px', paddingTop: '18px', borderTop: `1px solid ${E.hairline}` }}>
            <div style={{ fontFamily: E.sans, fontSize: '24px', color: E.text, fontWeight: 500, marginBottom: '14px' }}>
              README · <span style={{ color: E.orange }}>preview</span>
            </div>
            <p style={{ fontFamily: E.sans, fontSize: '15px', lineHeight: 1.7, color: E.text2, margin: '0 0 18px' }}>
              BorgDock is a native dock for developers. PR review, SQL, CI checks
              and the small rituals of a workday — surfaced on the edge of your
              screen for 8+ hours a day.
            </p>

            <div class="e-modes" style={{ marginTop: '12px' }}>
              {modes.map(([mode, sub, c], i) => (
                <div style={{
                  background: E.panel, border: `1px solid ${E.hairline}`,
                  padding: '12px', borderRadius: '6px', fontFamily: E.sans,
                }}>
                  <div style={{ fontFamily: E.mono, fontSize: '10px', color: c, letterSpacing: '0.08em' }}>MODE 0{i + 1}</div>
                  <div style={{ fontSize: '13px', color: E.text, marginTop: '4px' }}>{mode}</div>
                  <div style={{ fontSize: '11px', color: E.text3, marginTop: '4px' }}>{sub}</div>
                </div>
              ))}
            </div>

            <div style={{ marginTop: '22px', fontFamily: E.sans, fontSize: '14px', lineHeight: 1.7, color: E.text2 }}>
              <div style={{ fontFamily: E.mono, fontSize: '12px', color: E.purple, marginBottom: '6px' }}>## philosophy</div>
              I built BorgDock because every tool I tried felt designed for someone
              else's rituals. Mine are: PRs first thing, SQL midday, release notes
              at 6pm. Now they live in one always-on sidebar.
            </div>
          </div>
        </div>
      </div>
    </main>
  </div>

  <div style={{
    position: 'sticky', bottom: 0,
    display: 'flex', justifyContent: 'space-between', padding: '4px 14px',
    background: E.purple, color: '#11111b',
    fontFamily: E.mono, fontSize: '10.5px', fontWeight: 500,
  }}>
    <span class="e-status-l" style={{ display: 'flex', gap: '16px' }}>
      <span>⎇ main</span><span>○ 0 ⚠ 0</span><span>UTF-8</span>
    </span>
    <span class="e-status-r" style={{ display: 'flex', gap: '16px' }}>
      <span>Ln 12, Col 8</span><span>Spaces: 2</span><span>JSON</span><span>○ Catppuccin Mocha</span>
    </span>
  </div>
</div>
</body>
</html>
