---
import Base from '../../layouts/Base.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('posts', ({ data }) => !data.draft))
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

const fmt = (d: Date) => d.toISOString().slice(0, 10);
---

<Base title="Blog" terminalPath="~/blog" tagline="Notes, war stories, and series in progress.">
  <section class="section">
    <h2 class="section-title">all_posts</h2>
    <div class="posts-grid">
      { posts.map(post => (
        <a href={`/blog/${post.id}/`} class="post-card">
          <div class="post-meta">
            <span>{fmt(post.data.date)}</span>
            { post.data.tags?.length > 0 && <span>•</span> }
            { post.data.tags?.length > 0 && <span>{post.data.tags.join(', ')}</span> }
          </div>
          <h3 class="post-title-card">{post.data.title}</h3>
          { post.data.subtitle && <p class="post-excerpt"><em>{post.data.subtitle}</em></p> }
        </a>
      )) }
      { posts.length === 0 && (
        <p class="post-excerpt">Nothing here yet. Check back soon.</p>
      ) }
    </div>
  </section>
</Base>
